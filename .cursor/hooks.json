    "preToolUse": [{ "command": "bash .cursor/hooks/stayon-event.sh" }],
    "postToolUse": [{ "command": "bash .cursor/hooks/stayon-event.sh" }],
    "afterAgentThought": [{ "command": "bash .cursor/hooks/stayon-event.sh" }],
    "subagentStart": [{ "command": "bash .cursor/hooks/stayon-event.sh" }],
    "subagentStop": [{ "command": "bash .cursor/hooks/stayon-event.sh" }],
