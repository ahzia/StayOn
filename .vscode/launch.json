{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run StayOn Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/extension",
        "--user-data-dir=${workspaceFolder}/.vscode-ext-dev-profile",
        "${workspaceFolder}/.worktrees/ext-dev"
      ],
      "outFiles": ["${workspaceFolder}/extension/dist/**/*.js"],
      "preLaunchTask": "stayon: prelaunch"
    }
  ]
}
