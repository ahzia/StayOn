# Copy to web/.env.local for the Next.js backend.
# Never commit .env or .env.local — see root .gitignore

# CPX Research (publisher.cpx-research.com → your app)
CPX_APP_ID=
CPX_SECURE_HASH=

# Share of publisher USD (legacy — credits use amount_local from CPX postback)
CPX_USER_SHARE=0.5

# CPX Reward Settings currency factor (1 USD paid to you = N Points shown to user)
CPX_CURRENCY_FACTOR=700

# Dev only: skip CPX IP whitelist (NEVER in production)
CPX_SKIP_IP_CHECK=false

# Public URL of deployed web app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Extension (Cursor / VS Code settings — not read by backend)
# stayon.apiBaseUrl=http://localhost:3000
# stayon.cpxSurveys=true

# Future: BitLabs, Tremendous
# BITLABS_APP_TOKEN=
# BITLABS_APP_SECRET=
# TREMENDOUS_API_KEY=
